generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Billionaire {
  id            Int      @id @default(autoincrement())
  forbesId      Int      @unique
  name          String
  netWorth      Float    // in billions
  country       String
  photoUrl      String
  source        String   // source of wealth
  rank          Int
  elo           Float    @default(1400)
  eloBoost      Float    @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  votesAsWinner Vote[]   @relation("winner")
  votesAsLoser  Vote[]   @relation("loser")
  boosts        Boost[]
}

model Boost {
  id             Int         @id @default(autoincrement())
  billionaireId  Int
  amountUsd      Float
  eloAmount      Float
  paypalOrderId  String      @unique
  paypalPayerId  String?
  boosterName    String?
  status         String      @default("completed")
  createdAt      DateTime    @default(now())

  billionaire    Billionaire @relation(fields: [billionaireId], references: [id])
}

model Vote {
  id        Int          @id @default(autoincrement())
  winnerId  Int
  loserId   Int
  voterName String?
  winner    Billionaire  @relation("winner", fields: [winnerId], references: [id])
  loser     Billionaire  @relation("loser", fields: [loserId], references: [id])
  createdAt DateTime     @default(now())
}

model SiteStats {
  id           Int      @id @default(1)
  visitorCount Int      @default(0)
  updatedAt    DateTime @updatedAt
}
